params {
    fastq_dir   = "/home/users/nus/e1668109/scratch/5004/data/fastq"
    results_dir = "/home/users/nus/e1668109/scratch/5004/results"
    refs_dir    = "/home/users/nus/e1668109/scratch/5004/refs"
    genome_fa   = "${params.refs_dir}/Mus_musculus.GRCm39.dna.primary_assembly.fa"
    genome_gtf  = "${params.refs_dir}/Mus_musculus.GRCm39.112.gtf"
    star_index  = "${params.refs_dir}/star_index"
    threads     = 8
}

conda.enabled = true

process {
    executor = 'pbs'
    conda    = '/home/users/nus/e1668109/miniconda3/envs/rnaseq'
    cpus     = 4
    memory   = '16 GB'
    time     = '2h'

    withName: 'FASTQC' {
        cpus   = 4
        memory = '8 GB'
        time   = '1h'
    }
    withName: 'TRIM' {
        cpus   = 4
        memory = '8 GB'
        time   = '2h'
    }
    withName: 'STAR_INDEX' {
        cpus   = 16
        memory = '64 GB'
        time   = '1h 55m'
    }
    withName: 'STAR_ALIGN' {
        cpus   = 16
        memory = '64 GB'
        time   = '1h 55m'
    }
    withName: 'FEATURE_COUNTS' {
        cpus   = 8
        memory = '32 GB'
        time   = '2h'
    }
    withName: 'MULTIQC' {
        cpus   = 2
        memory = '8 GB'
        time   = '30m'
    }
}

executor {
    queueStatInterval = '1 min'
    pollInterval      = '30 sec'
    submitRateLimit   = '10/1min'
    queueSize         = 20
}

report {
    enabled   = true
    overwrite = true
    file      = "/home/users/nus/e1668109/scratch/5004/logs/pipeline_report.html"
}

timeline {
    enabled   = true
    overwrite = true
    file      = "/home/users/nus/e1668109/scratch/5004/logs/pipeline_timeline.html"
}
